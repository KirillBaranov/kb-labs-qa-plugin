{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@kb-labs/plugin-contracts": [
        "../kb-labs-plugin/packages/plugin-contracts/src/index.ts"
      ],
      "@kb-labs/plugin-contracts/*": [
        "../kb-labs-plugin/packages/plugin-contracts/src/*"
      ],
      "@kb-labs/plugin-runtime": [
        "../kb-labs-plugin/packages/plugin-runtime/src/index.ts"
      ],
      "@kb-labs/plugin-runtime/*": [
        "../kb-labs-plugin/packages/plugin-runtime/src/*"
      ],
      "@kb-labs/qa-contracts": [
        "packages/qa-contracts/src/index.ts"
      ],
      "@kb-labs/qa-contracts/*": [
        "packages/qa-contracts/src/*"
      ],
      "@kb-labs/qa-core": [
        "packages/qa-core/src/index.ts"
      ],
      "@kb-labs/qa-core/*": [
        "packages/qa-core/src/*"
      ],
      "@kb-labs/qa-cli": [
        "packages/qa-cli/src/index.ts"
      ],
      "@kb-labs/qa-cli/*": [
        "packages/qa-cli/src/*"
      ],
      "@kb-labs/sdk": [
        "../kb-labs-sdk/packages/sdk/src/index.ts"
      ],
      "@kb-labs/sdk/*": [
        "../kb-labs-sdk/packages/sdk/src/*"
      ]
    }
  }
}
